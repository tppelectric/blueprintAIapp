NODE_ENV=production

# Web app
WEB_URL=https://staging.blueprintaiapp.example
API_BASE_URL=https://blueprint-api-staging.example

# API service
API_PORT=4000
SCANNER_URL=https://blueprint-scanner-staging.example
CORS_ALLOWED_ORIGINS=https://staging.blueprintaiapp.example

# Auth and tenancy
APP_TENANCY_MODE=multi_company
PRIMARY_COMPANY_ID=company-primary
AUTH_REQUIRED=true
RBAC_ENFORCED=true
ALLOW_DEV_TENANT_HEADER=false
JWT_SECRET=replace-with-long-random-secret
SESSION_SECRET=replace-with-long-random-secret
RESET_TOKEN_SECRET=replace-with-long-random-secret

# Database
DATABASE_URL=postgres://user:password@host:5432/blueprint_ai_staging
DB_SCHEMA_CHECK_ENABLED=true

# Scanner and uploads
LOCAL_UPLOAD_DIR=/var/lib/blueprint/uploads/plans
SCANNER_REAL_REQUIRE_YOLO=false

# Optional jobs
MATERIAL_PRICE_SCHEDULER_ENABLED=false
MATERIAL_PRICE_SCHEDULER_INTERVAL_MS=3600000

# External integrations
JOBTREAD_API_KEY=
JOBTREAD_BASE_URL=https://api.jobtread.com
